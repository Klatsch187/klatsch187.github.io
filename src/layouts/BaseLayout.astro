---
/**
 * BaseLayout — the shared HTML shell for every page.
 * Provides: <head> meta, design-system stylesheet, no-flash theme init,
 * skip link, site nav, footer, and the main content slot.
 *
 * Props:
 *   title       {string}  page <title> (site name is appended)
 *   description {string=} meta description
 *   activeNav   {string=} id of the current nav item for aria-current
 */
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description = 'Personal site of Klatsch187 — about me in charts, mini-games, and reviews.',
  activeNav,
} = Astro.props;

const siteName = 'klatsch187';
const fullTitle = title ? `${title} · ${siteName}` : siteName;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />

    {/* Design system fonts: Fraunces (serif display) + Inter (grotesque). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;600;700&display=swap"
    />

    {/* No-flash theme init: runs before paint, reads saved/system preference. */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          /* localStorage may be unavailable; default stays 'light' */
        }
      })();
    </script>

    {/* Scroll-FX gate: enable scroll/entrance animations ONLY when JS runs and
        the user hasn't asked for reduced motion. Runs before paint so the hero
        entrance has no flash. CSS hides things only inside `.scroll-fx`, so
        without this class all content stays fully visible. */}
    <script is:inline>
      (function () {
        try {
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('scroll-fx');
          }
        } catch (e) {
          /* leave content fully visible */
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav activeNav={activeNav} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* Reveal-on-scroll: one shared observer adds `.is-visible` to reveal
        targets and animated underlines as they enter the viewport, then stops
        watching them. Only runs when the scroll-FX gate is on. */}
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains('scroll-fx')) return;
        var els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('is-visible'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.15 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
