---
/**
 * BaseLayout — the shared HTML shell for every page.
 * Provides: <head> meta, design-system stylesheet, no-flash theme init,
 * skip link, site nav, footer, and the main content slot.
 *
 * Props:
 *   title       {string}  page <title> (site name is appended)
 *   description {string=} meta description
 *   activeNav   {string=} id of the current nav item for aria-current
 */
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description = 'Personal site of Klatsch187 — about me in charts, mini-games, and reviews.',
  activeNav,
} = Astro.props;

const siteName = 'klatsch187';
const fullTitle = title ? `${title} · ${siteName}` : siteName;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />

    {/* No-flash theme init: runs before paint, reads saved/system preference. */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          /* localStorage may be unavailable; default stays 'light' */
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav activeNav={activeNav} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
