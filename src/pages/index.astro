---
/**
 * About Me — landing page. Hero + four data visualizations + timeline.
 * Each chart is a self-contained component driven by its own data file.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WorldMap from '../components/charts/WorldMap.astro';
import RadarChart from '../components/charts/RadarChart.astro';
import IronmanTraining from '../components/charts/IronmanTraining.astro';
import SkillsArea from '../components/charts/SkillsArea.astro';
import Timeline from '../components/charts/Timeline.astro';
---

<BaseLayout title="About" activeNav="about">
  <Hero />

  <div class="container">
    <p class="placeholder-note">
      📝 Everything below is <strong>placeholder data</strong>. Edit the JSON
      files in <code>src/data/</code> to make it yours — no chart code changes
      needed.
    </p>
  </div>

  {/* --- Visited countries map --- */}
  <section id="map" class="section container">
    <header class="section__head">
      <p class="section__eyebrow">Where I've been</p>
      <h2>Countries visited</h2>
      <p class="section__lead">
        A world map driven by <code>countries-visited.json</code>. Hover a
        highlighted country for details.
      </p>
    </header>
    <WorldMap />
  </section>

  {/* --- Ironman training (Strava-driven) --- */}
  <section id="ironman" class="section container">
    <header class="section__head">
      <p class="section__eyebrow">Chasing a finish line</p>
      <h2>Ironman training</h2>
      <p class="section__lead">
        Weekly volume by discipline, a heart-rate-derived fitness trend, and
        readiness for race day — driven by <code>ironman-training.json</code>
        (placeholder until <a href="https://github.com/Klatsch187/klatsch187.github.io#ironman-training-strava">Strava is connected</a>).
      </p>
    </header>
    <IronmanTraining />
  </section>

  {/* --- Personal traits radar --- */}
  <section id="metrics" class="section container">
    <header class="section__head">
      <p class="section__eyebrow">Me, quantified-ish</p>
      <h2>Traits</h2>
      <p class="section__lead">A radar chart of self-rated traits.</p>
    </header>
    <div class="radar-wrap">
      <RadarChart />
    </div>
  </section>

  {/* --- Skills over time --- */}
  <section id="skills" class="section container">
    <header class="section__head">
      <p class="section__eyebrow">Leveling up</p>
      <h2>Skills over time</h2>
      <p class="section__lead">Stacked area of proficiency by year.</p>
    </header>
    <SkillsArea />
  </section>

  {/* --- Life timeline --- */}
  <section id="timeline" class="section container">
    <header class="section__head">
      <p class="section__eyebrow">The story so far</p>
      <h2>Life timeline</h2>
      <p class="section__lead">Milestones, in order.</p>
    </header>
    <Timeline />
  </section>
</BaseLayout>

<style>
  /* Keep the radar from stretching too wide on large screens. */
  .radar-wrap { max-width: 460px; margin-inline: auto; }
  code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface-2);
    padding: 1px 5px;
    border-radius: 4px;
  }
</style>
