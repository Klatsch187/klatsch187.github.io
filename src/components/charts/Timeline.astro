---
/**
 * Timeline — life events as a semantic, accessible ordered list (no JS).
 * Driven by src/data/timeline.json. Rendered server-side => fast + a11y-friendly.
 */
import timeline from '../../data/timeline.json';

// Sort ascending by year so the story reads top-to-bottom.
const events = [...timeline.events].sort((a, b) => a.year - b.year);
---

<ol class="timeline" aria-label="Timeline of life events">
  {
    events.map((e, i) => (
      <li class="timeline__item reveal" style={`--reveal-i: ${i}`}>
        <span class="timeline__dot" aria-hidden="true">{e.icon ?? '•'}</span>
        <div class="timeline__content card">
          <p class="timeline__year">{e.year}</p>
          <h3 class="timeline__title">{e.title}</h3>
          {e.description && <p class="timeline__desc">{e.description}</p>}
        </div>
      </li>
    ))
  }
</ol>

<style>
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  /* The vertical spine */
  .timeline::before {
    content: '';
    position: absolute;
    left: 19px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--color-border);
  }
  .timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--space-4);
    padding-block: var(--space-2);
  }
  .timeline__dot {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    font-size: 1.1rem;
    z-index: 1;
  }
  .timeline__content { padding: var(--space-3) var(--space-4); }
  .timeline__year {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }
  .timeline__title { margin: var(--space-1) 0 0; font-size: var(--text-lg); }
  .timeline__desc {
    margin: var(--space-2) 0 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
</style>
