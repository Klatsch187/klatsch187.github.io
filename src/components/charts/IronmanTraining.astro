---
/**
 * IronmanTraining — training-progress panel driven by src/data/ironman-training.json
 * (placeholder via `npm run gen:ironman`, or live via `npm run fetch:strava`).
 *
 * Three things, per the design:
 *   1. Summary tiles  (days to race, sessions, hours, this week)
 *   2. Readiness gauge (recent 4-wk avg weekly hours vs peak target)
 *   3. Weekly volume by discipline (stacked bar) + HR-derived fitness trend (line)
 *
 * Charts reuse the Chart.js + theming pattern from RadarChart/SkillsArea.
 */
import data from '../../data/ironman-training.json';

const weeks = data.weeks ?? [];
const peak = data.targets?.peakWeeklyHours ?? 14;
const isPlaceholder = data.source === 'placeholder';

const weekTotal = (w) => (w.hours.swim ?? 0) + (w.hours.bike ?? 0) + (w.hours.run ?? 0);
const thisWeekHours = weeks.length ? weekTotal(weeks[weeks.length - 1]) : 0;

// Readiness = recent 4-week average weekly hours vs the peak-week target.
const recent = weeks.slice(-4);
const recent4avg = recent.length
  ? recent.reduce((sum, w) => sum + weekTotal(w), 0) / recent.length
  : 0;
const readinessPct = Math.max(0, Math.min(100, Math.round((recent4avg / peak) * 100)));

const fmt1 = (n) => Number(n).toFixed(1);
---
<div class="im card">
  {isPlaceholder && (
    <p class="placeholder-note im__note">
      🏊 🚴 🏃 Placeholder training data. Connect Strava (see the README) to drive
      this from real activities — heart rate &amp; moving time included.
    </p>
  )}

  <h3 class="im__race">{data.race?.name ?? 'Ironman'} <span class="im__dist">{data.race?.distanceKey}</span></h3>

  {/* 1) Summary tiles */}
  <dl class="im__tiles">
    <div class="im__tile">
      <dt>Days to race</dt>
      <dd id="im-countdown" data-race-date={data.race?.date}>—</dd>
    </div>
    <div class="im__tile">
      <dt>Sessions</dt>
      <dd>{data.totals?.sessions ?? 0}</dd>
    </div>
    <div class="im__tile">
      <dt>Total hours</dt>
      <dd>{fmt1(data.totals?.movingHours ?? 0)}</dd>
    </div>
    <div class="im__tile">
      <dt>This week</dt>
      <dd>{fmt1(thisWeekHours)}<span class="im__unit">h</span></dd>
    </div>
  </dl>

  {/* 2) Readiness gauge */}
  <div class="im__gauge">
    <div class="im__gauge-head">
      <span>Race readiness</span>
      <strong>{readinessPct}%</strong>
    </div>
    <div
      class="im__bar"
      role="progressbar"
      aria-valuenow={readinessPct}
      aria-valuemin="0"
      aria-valuemax="100"
      aria-label={`Race readiness ${readinessPct} percent of peak weekly volume`}
    >
      <div class="im__bar-fill" style={`width:${readinessPct}%`}></div>
    </div>
    <p class="im__gauge-sub">
      Recent 4-week avg <strong>{fmt1(recent4avg)} h/wk</strong> vs
      <strong> {peak} h/wk</strong> peak target.
    </p>
  </div>

  {/* 3) Charts */}
  <div class="im__charts">
    <figure class="im__chart">
      <figcaption>Weekly volume by discipline (hours)</figcaption>
      <div class="im__canvas-wrap">
        <canvas id="im-volume" role="img"
          aria-label="Stacked bar chart of weekly swim, bike, and run hours"></canvas>
      </div>
    </figure>
    <figure class="im__chart">
      <figcaption>Fitness trend (training load)</figcaption>
      <div class="im__canvas-wrap">
        <canvas id="im-fitness" role="img"
          aria-label="Line chart of weekly training load derived from heart rate and moving time"></canvas>
      </div>
    </figure>
  </div>
</div>

<style>
  .im { padding: var(--space-5); display: grid; gap: var(--space-5); }
  .im__note { margin: 0; }
  .im__race { margin: 0; font-size: var(--text-lg); }
  .im__dist {
    font-size: var(--text-xs); font-weight: 700; vertical-align: middle;
    margin-left: var(--space-2); padding: 2px 8px; border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent);
  }

  .im__tiles {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .im__tile {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface-2);
  }
  .im__tile dt {
    font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--color-text-muted);
  }
  .im__tile dd { margin: var(--space-1) 0 0; font-size: var(--text-2xl); font-weight: 800; }
  .im__unit { font-size: var(--text-base); font-weight: 600; color: var(--color-text-muted); margin-left: 2px; }

  .im__gauge-head { display: flex; justify-content: space-between; font-size: var(--text-sm); margin-bottom: var(--space-2); }
  .im__bar { height: 12px; border-radius: 999px; background: var(--color-surface-2); overflow: hidden; border: 1px solid var(--color-border); }
  .im__bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--viz-3), var(--viz-1));
    border-radius: 999px;
    transition: width var(--transition);
  }
  .im__gauge-sub { margin: var(--space-2) 0 0; font-size: var(--text-sm); color: var(--color-text-muted); }

  .im__charts { display: grid; grid-template-columns: 1.3fr 1fr; gap: var(--space-5); }
  .im__chart { margin: 0; }
  .im__chart figcaption { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-2); }
  .im__canvas-wrap { position: relative; aspect-ratio: 16 / 10; }

  @media (max-width: 760px) {
    .im__tiles { grid-template-columns: repeat(2, 1fr); }
    .im__charts { grid-template-columns: 1fr; }
  }
</style>

<script>
  import {
    Chart,
    BarController, BarElement,
    LineController, LineElement, PointElement,
    LinearScale, CategoryScale,
    Filler, Tooltip,
  } from 'chart.js';
  import data from '../../data/ironman-training.json';
  import { cssVar, vizPalette, withAlpha, onThemeChange } from '../../lib/chartTheme.js';

  Chart.register(
    BarController, BarElement, LineController, LineElement, PointElement,
    LinearScale, CategoryScale, Filler, Tooltip
  );

  const weeks = data.weeks ?? [];

  // --- Countdown (computed client-side so it's right between rebuilds) ---
  const countdownEl = document.getElementById('im-countdown');
  if (countdownEl?.dataset.raceDate) {
    const race = new Date(countdownEl.dataset.raceDate + 'T00:00:00');
    const days = Math.ceil((race - new Date()) / 86400000);
    countdownEl.textContent = days > 0 ? String(days) : days === 0 ? 'Today!' : 'Done';
  }

  // Parse 'YYYY-MM-DD' as a local date and label it "Mar 3".
  const labelFmt = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric' });
  const labels = weeks.map((w) => {
    const [y, m, d] = w.weekStart.split('-').map(Number);
    return labelFmt.format(new Date(y, m - 1, d));
  });

  const volumeCanvas = document.getElementById('im-volume');
  const fitnessCanvas = document.getElementById('im-fitness');
  let volumeChart, fitnessChart;

  function buildVolume() {
    const [swimC, bikeC, runC] = vizPalette();
    const text = cssVar('--color-text-muted');
    const grid = cssVar('--color-border');
    const series = [
      { label: 'Swim', key: 'swim', color: swimC },
      { label: 'Bike', key: 'bike', color: bikeC },
      { label: 'Run', key: 'run', color: runC },
    ];
    volumeChart = new Chart(volumeCanvas, {
      type: 'bar',
      data: {
        labels,
        datasets: series.map((s) => ({
          label: s.label,
          data: weeks.map((w) => w.hours[s.key] ?? 0),
          backgroundColor: s.color,
          borderRadius: 3,
          stack: 'vol',
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { color: text, usePointStyle: true, boxHeight: 7 } } },
        scales: {
          x: { stacked: true, grid: { display: false }, ticks: { color: text, maxRotation: 0, autoSkipPadding: 12 } },
          y: { stacked: true, grid: { color: grid }, ticks: { color: text }, title: { display: true, text: 'hours', color: text } },
        },
      },
    });
  }

  function buildFitness() {
    const accent = cssVar('--color-accent');
    const text = cssVar('--color-text-muted');
    const grid = cssVar('--color-border');
    fitnessChart = new Chart(fitnessCanvas, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Training load',
            data: weeks.map((w) => w.load ?? 0),
            borderColor: accent,
            backgroundColor: withAlpha(accent, 0.15),
            pointBackgroundColor: accent,
            fill: true,
            tension: 0.35,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              // Surface heart rate alongside the load value.
              afterLabel: (ctx) => {
                const hr = weeks[ctx.dataIndex]?.avgHr;
                return hr ? `Avg HR: ${hr} bpm` : '';
              },
            },
          },
        },
        scales: {
          x: { grid: { display: false }, ticks: { color: text, maxRotation: 0, autoSkipPadding: 12 } },
          y: { grid: { color: grid }, ticks: { color: text }, beginAtZero: true },
        },
      },
    });
  }

  function buildAll() {
    if (volumeCanvas) buildVolume();
    if (fitnessCanvas) buildFitness();
  }
  buildAll();
  onThemeChange(() => {
    volumeChart?.destroy();
    fitnessChart?.destroy();
    buildAll();
  });
</script>
