---
/**
 * Hero — editorial masthead for the About page. Driven by src/data/profile.json.
 * Serif display name, a dateline eyebrow, a justified standfirst with a
 * drop-cap, and a hairline-divided spec list of quick-facts. Elements carry
 * `data-fx-rise` so they fade/rise in a staggered cascade on load
 * (gated by `.scroll-fx`; static otherwise).
 */
import profile from '../data/profile.json';
---
<header class="hero">
  <div class="container hero__inner">
    <p class="hero__dateline" data-fx-rise style="--fx-i: 0">
      <span>{profile.location}</span>
      <span class="hero__mark" aria-hidden="true">{profile.avatarEmoji}</span>
    </p>

    <h1 class="hero__name" data-fx-rise style="--fx-i: 1">{profile.name}</h1>
    <p class="hero__tagline" data-fx-rise style="--fx-i: 2">{profile.tagline}</p>

    <div class="hero__grid">
      <p class="hero__standfirst" data-fx-rise style="--fx-i: 3">{profile.intro}</p>

      <dl class="hero__facts" data-fx-rise style="--fx-i: 4">
        {
          profile.quickFacts.map((f) => (
            <div class="hero__fact">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <ul class="hero__links" data-fx-rise style="--fx-i: 5">
      {
        profile.links.map((l) => (
          <li>
            <a href={l.url}>{l.label} <span aria-hidden="true">→</span></a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<style>
  .hero {
    padding-block: var(--space-8) var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }
  .hero__inner { max-width: 960px; }
  .hero__dateline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 0 var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    font-variant: all-small-caps;
    letter-spacing: 0.18em;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .hero__mark { font-size: 1.2rem; letter-spacing: 0; }
  .hero__name {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.98;
    margin: 0;
    letter-spacing: -0.03em;
  }
  /* This masthead name has no accent rule under it (only section heads do). */
  .hero__name::after { content: none; }
  .hero__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    margin: var(--space-3) 0 var(--space-6);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  .hero__standfirst {
    font-size: var(--text-lg);
    line-height: 1.6;
    margin: 0;
    max-width: 46ch;
  }
  .hero__standfirst::first-letter {
    font-family: var(--font-serif);
    font-size: 3.2em;
    font-weight: 600;
    float: left;
    line-height: 0.78;
    padding: 0.05em 0.12em 0 0;
    color: var(--color-accent);
  }
  .hero__facts { margin: 0; }
  .hero__fact {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .hero__fact:first-child { border-top: 1px solid var(--color-border); }
  .hero__fact dt {
    font-variant: all-small-caps;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
  .hero__fact dd {
    margin: 0;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .hero__links {
    list-style: none;
    margin: var(--space-7) 0 0;
    padding: 0;
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .hero__links a {
    font-weight: 600;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 2px;
  }
  .hero__links a:hover { text-decoration: none; color: var(--color-accent); }

  @media (max-width: 720px) {
    .hero__grid { grid-template-columns: 1fr; gap: var(--space-5); }
  }
</style>
