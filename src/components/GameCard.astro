---
/**
 * GameCard — one entry in the games grid. Built from a registry entry.
 */
import { withBase } from '../lib/paths.js';

const { game } = Astro.props;
const href = withBase(`/games/${game.id}/`);
const thumb = withBase(game.thumbnail);
---
<a class="game-card card" href={href} style={game.accent ? `--card-accent:${game.accent}` : undefined}>
  <div class="game-card__media">
    <img src={thumb} alt={`${game.title} thumbnail`} loading="lazy" width="400" height="240" />
  </div>
  <div class="game-card__body">
    <h3 class="game-card__title">{game.title}</h3>
    <p class="game-card__desc">{game.description}</p>
    {game.tags && (
      <ul class="game-card__tags">
        {game.tags.map((t) => <li class="tag">{t}</li>)}
      </ul>
    )}
    <span class="game-card__cta">Play →</span>
  </div>
</a>

<style>
  .game-card {
    --card-accent: var(--color-accent);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    color: inherit;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }
  .game-card:hover {
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--card-accent);
  }
  .game-card__media { aspect-ratio: 5 / 3; overflow: hidden; background: var(--color-surface-2); }
  .game-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .game-card__body { padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .game-card__title { margin: 0; font-size: var(--text-lg); }
  .game-card__desc { margin: 0; color: var(--color-text-muted); font-size: var(--text-sm); flex: 1; }
  .game-card__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); list-style: none; margin: var(--space-1) 0 0; padding: 0; }
  .game-card__cta { color: var(--card-accent); font-weight: 700; font-size: var(--text-sm); }
</style>
